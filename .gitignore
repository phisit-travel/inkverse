# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# database files
*.db
*.db-journal
*.db-shm
*.db-wal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
test-*.mjs

# local test artifacts / screenshots / logs (root-level only)
/*.png
/*.jpg
/*.jpeg
*.log

# verification screenshot folders (local only)
/bal-after/
/bal-audit/

.vercel

# SECRETS — never commit (Firebase keys live in Vercel env only)
google-services.json
**/google-services.json
*firebase-adminsdk*.json
serviceAccount*.json
json-to-base64-converter.txt
*service-account*.json

# local build artifacts / IDE
inkverse-android-apk/
inkverse-android-apk.zip
*.apk
# Exception: published app downloads MUST be tracked.
!public/downloads/*.apk
mobile/.idea/
.idea/
