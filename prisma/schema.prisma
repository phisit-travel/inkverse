generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  username         String            @unique
  email            String            @unique
  passwordHash     String?
  role             String            @default("READER")
  avatarUrl        String?
  coverUrl         String?           // profile banner image (R2 URL)
  bio              String?           // short profile bio (readers; translators use Translator.bio)
  verifiedAt       DateTime?         // identity-verified translator (paid + admin-approved)
  coins            Int               @default(0)
  vipExpiresAt     DateTime?         // active VIP while in the future (coin stipend + unlock discount)
  createdAt        DateTime          @default(now())
  // Fields required by @auth/prisma-adapter for OAuth (Google) sign-in
  name             String?
  image            String?
  emailVerified    DateTime?
  accounts         Account[]
  sessions         Session[]
  bookmarks        Bookmark[]
  readHistory      ReadHistory[]
  comments         Comment[]
  commentLikes     CommentLike[]
  ratings          Rating[]
  translator       Translator?
  coinTransactions        CoinTransaction[]
  unlockedChapters        UnlockedChapter[]
  translatorApplication   TranslatorApplication?
  coinOrders              CoinOrder[]
  notifications           Notification[]
  dailyCheckIns           DailyCheckIn[]
  referralsGiven          Referral[]        @relation("Referrer")
  referralReceived        Referral?         @relation("Referee")
  contactMessages         ContactMessage[]
  verificationRequest     VerificationRequest?
  passwordResetTokens     PasswordResetToken[]
  achievements            UserAchievement[]
}

// Unlocked achievements. Definitions live in code (lib/achievements.ts); this
// table only records which keys a user has earned (one row per unlock).
model UserAchievement {
  userId         String
  achievementKey String
  unlockedAt     DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, achievementKey])
  @@index([userId])
}

// Lightweight daily traffic counter (page views + per-day unique visitors).
model DailyStat {
  day       String @id // "YYYY-MM-DD" (UTC)
  pageViews Int    @default(0)
  visitors  Int    @default(0)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique // random, emailed to the user
  userId    String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationRequest {
  id         String    @id @default(cuid())
  userId     String    @unique
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED
  coinsPaid  Int
  adminNote  String?
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?  // null when sent by a logged-out visitor
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("OPEN") // OPEN | RESOLVED
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model Referral {
  id           String    @id @default(cuid())
  referrerId   String
  refereeId    String    @unique // a user can only be referred once
  status       String    @default("PENDING") // PENDING | REWARDED
  coinsAwarded Int       @default(0)
  createdAt    DateTime  @default(now())
  rewardedAt   DateTime?
  referrer     User      @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee      User      @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

model CoinOrder {
  id             String    @id @default(cuid())
  userId         String
  packageId      String
  coins          Int
  bonus          Int       @default(0)
  vipDays        Int       @default(0) // >0 → grants this many VIP days when paid
  price          Float
  status         String    @default("PENDING") // PENDING | PAID | FAILED | CANCELLED
  method         String?   // CARD | PROMPTPAY
  paidAt         DateTime?
  omiseChargeId  String?
  slipUrl        String?   // PromptPay payment slip (R2 URL)
  slipRef        String?   @unique // EasySlip transRef — prevents reusing a slip
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Manga {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  description   String
  coverUrl      String?
  originCountry String      @default("JP")
  status        String      @default("ONGOING")
  type          String      @default("MANGA")
  totalViews    Int         @default(0)
  contentRating String      @default("EVERYONE") // EVERYONE | TEEN | ADULT
  // Attribution for openly-licensed (e.g. CC-BY) imported works
  author        String?
  sourceUrl     String?
  license       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  genres        MangaGenre[]
  chapters      Chapter[]
  bookmarks     Bookmark[]
  ratings       Rating[]
  weeklyStats   WeeklyStats[]
  translatorId  String?
  translator    Translator? @relation(fields: [translatorId], references: [id])
}

model Genre {
  id     String       @id @default(cuid())
  name   String       @unique
  slug   String       @unique
  mangas MangaGenre[]
}

model MangaGenre {
  mangaId String
  genreId String
  manga   Manga  @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([mangaId, genreId])
}

model Translator {
  id         String  @id @default(cuid())
  userId     String  @unique
  penName    String
  bio        String?
  totalWorks Int     @default(0)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mangas     Manga[]
  earnings           TranslatorEarning[]
  withdrawalRequests WithdrawalRequest[]
}

model TranslatorEarning {
  id           String     @id @default(cuid())
  translatorId String
  chapterId    String?    // null for tips (not tied to a chapter)
  mangaId      String?    // null for tips
  userId       String
  type         String     @default("UNLOCK") // UNLOCK | TIP
  coinsSpent   Int
  amount       Float      // THB after platform fee
  createdAt    DateTime   @default(now())
  translator   Translator @relation(fields: [translatorId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id               String     @id @default(cuid())
  translatorId     String
  amount           Float
  status           String     @default("PENDING") // PENDING | PROCESSING | PAID | FAILED | REJECTED
  paymentMethod    String     // PROMPTPAY | BANK_TRANSFER
  accountName      String
  accountNumber    String
  bankName         String?
  bankCode         String?    // Omise bank code: kbank, scb, bbl, etc.
  adminNote        String?
  omiseRecipientId String?
  omiseTransferId  String?
  requestedAt      DateTime   @default(now())
  processedAt      DateTime?
  translator       Translator @relation(fields: [translatorId], references: [id], onDelete: Cascade)
}

model Chapter {
  id               String            @id @default(cuid())
  mangaId          String
  chapterNum       Float
  title            String?
  isPremium        Boolean           @default(false)
  coinCost         Int               @default(0)
  publishedAt      DateTime          @default(now())
  viewCount        Int               @default(0)
  content          String?           @db.Text // novel chapter body (HTML from the WYSIWYG editor); null for image manga
  authorNote       String?           @db.Text // optional note shown at the end of a novel chapter
  status           String            @default("PUBLISHED") // DRAFT | PUBLISHED
  publishAt        DateTime?         // future timestamp for scheduled release; null = live now
  manga            Manga             @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  pages            Page[]
  readHistory      ReadHistory[]
  comments         Comment[]
  unlockedBy       UnlockedChapter[]

  @@unique([mangaId, chapterNum])
}

model Page {
  id        String  @id @default(cuid())
  chapterId String
  pageNum   Int
  imageUrl  String
  width     Int?
  height    Int?
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, pageNum])
}

model Bookmark {
  userId    String
  mangaId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@id([userId, mangaId])
}

model ReadHistory {
  userId    String
  chapterId String
  lastPage  Int      @default(1)
  readAt    DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@id([userId, chapterId])
}

model Comment {
  id        String    @id @default(cuid())
  userId    String
  chapterId String
  content   String
  isSpoiler Boolean   @default(false)
  likes     Int       @default(0)
  createdAt DateTime  @default(now())
  parentId  String?
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter   Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  likedBy   CommentLike[]
}

// One row per (user, comment) like — makes liking idempotent + toggleable, and
// `Comment.likes` the denormalised count kept in sync on create/delete.
model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model Rating {
  userId    String
  mangaId   String
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@id([userId, mangaId])
}

model WeeklyStats {
  id           String   @id @default(cuid())
  mangaId      String
  period       String
  views        Int      @default(0)
  likes        Int      @default(0)
  bookmarks    Int      @default(0)
  rank         Int      @default(0)
  calculatedAt DateTime @default(now())
  manga        Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([mangaId, period])
}

model TranslatorApplication {
  id              String   @id @default(cuid())
  userId          String   @unique
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  penName         String
  experience      String
  sampleWork      String
  socialLink      String?
  preferredGenres String   @default("[]")
  motivation      String
  acceptedTerms   Boolean  @default(false)
  termsAcceptedAt DateTime?
  adminNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoinPackage {
  id          String   @id @default(cuid())
  name        String
  coins       Int
  price       Float
  bonus       Int      @default(0)
  vipDays     Int      @default(0) // >0 → this package also grants VIP days
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model CoinTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String   // "TOPUP" | "SPEND" | "BONUS" | "REFUND"
  description String
  refId       String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UnlockedChapter {
  userId      String
  chapterId   String
  unlockedAt  DateTime @default(now())
  coinSpent   Int      @default(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@id([userId, chapterId])
}

model DailyCheckIn {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime // truncated to 00:00 UTC of the claim day
  coinsEarned Int
  streak      Int      @default(1)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
